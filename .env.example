# Optional: use proxy (default in dev) or talk to backend directly.
# Leave unset to use /api proxy (no CORS; auth added by Vite).
# Set to backend URL to call it directly (backend must allow CORS for this origin).
# VITE_API_URL=http://localhost:8077

# API Basic auth (must match backend app.security.username / app.security.password).
# Copy to .env.local and set values; .env.local is gitignored.
# VITE_API_USERNAME=user
# VITE_API_PASSWORD=pass
